    {
      "name": "POST /api/units",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
              "pm.test(\"Unit is AVAILABLE\", () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.status).to.eql(\"AVAILABLE\");",
              "    pm.environment.set(\"unitId\", body.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Medical Unit 1\",\n    \"callSign\": \"MU-1\",\n    \"type\": \"MEDICAL\",\n    \"maxConcurrentCalls\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/units",
          "host": ["{{baseUrl}}"],
          "path": ["api", "units"]
        }
      }
    },
