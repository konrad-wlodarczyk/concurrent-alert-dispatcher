      "name": "POST /api/units",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
              "pm.test(\"Unit is AVAILABLE\", () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.status).to.eql(\"AVAILABLE\");",
              "    pm.environment.set(\"unitId\", body.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
